# AI WealthPilot - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# DeepSeek API Key (Primary — for AI Advisor Agent)
# Get your key at: https://platform.deepseek.com
# 在 DeepSeek 平台获取 Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (Optional — for future RAG modules, Phase 4)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Alternative LLM providers
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Data Sources (most are free, no key needed)
# FRED_API_KEY=your_fred_api_key_here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
